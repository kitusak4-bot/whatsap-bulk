NODE_ENV=production
HOST=127.0.0.1
PORT=3000
TRUST_PROXY=1

# Generate both with: openssl rand -base64 48
ADMIN_API_KEY=replace-with-a-long-random-bootstrap-key
API_KEY_PEPPER=replace-with-a-different-long-random-secret

DATABASE_PATH=./data/baileys.sqlite
LOG_LEVEL=info
BAILEYS_LOG_LEVEL=warn
LOG_FILE=./logs/app.log
LOG_RETENTION_DAYS=30

# Comma-separated origins allowed from browsers. Use * to allow ANY site/app/localhost
# (API-key auth is the real guard). List specific origins to lock it down instead.
CORS_ORIGINS=*

API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=120
ADMIN_RATE_LIMIT_MAX=20
MAX_MEDIA_BYTES=26214400
ALLOW_REMOTE_MEDIA=false
REMOTE_MEDIA_TIMEOUT_MS=15000
QR_WAIT_MS=15000
QR_TTL_MS=60000
RECONNECT_MAX_DELAY_MS=60000
CHECK_RECIPIENT_EXISTS=false

# Anti-ban send queue: one message at a time with a RANDOM gap between sends,
# picked fresh each time from this range (ms). 5-9s looks human and keeps the number safe.
MESSAGE_DELAY_MIN_MS=5000
MESSAGE_DELAY_MAX_MS=9000

# Dashboard API sections. Domain shown only when set; IP auto-detects if empty.
PUBLIC_DOMAIN=
PUBLIC_IP=
