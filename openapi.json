{
  "openapi": "3.0.3",
  "info": {
    "title": "whatsap-bulk API",
    "description": "Production WhatsApp REST API with anti-ban protection. Send messages, manage contacts, and run campaigns.",
    "version": "1.0.0",
    "contact": {
      "name": "kitusak4-bot",
      "url": "https://github.com/kitusak4-bot/whatsap-bulk"
    }
  },
  "servers": [
    { "url": "http://localhost:3000", "description": "Local development" }
  ],
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": false },
          "error": { "type": "string" },
          "code": { "type": "string" }
        }
      },
      "SendResult": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "data": {
            "type": "object",
            "properties": {
              "id": { "type": "string", "example": "msg_abc123" },
              "status": { "type": "string", "enum": ["sent", "queued", "failed"] }
            }
          }
        }
      },
      "Status": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "example": "connected" },
          "connected": { "type": "boolean" },
          "pendingMessages": { "type": "integer" },
          "sentToday": { "type": "integer" },
          "dailyLimit": { "type": "integer" },
          "user": { "type": "string" }
        }
      },
      "Message": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "recipient": { "type": "string" },
          "type": { "type": "string", "enum": ["text", "image", "document", "audio", "location"] },
          "preview": { "type": "string" },
          "status": { "type": "string", "enum": ["queued", "sent", "delivered", "read", "failed"] },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      }
    }
  },
  "security": [{ "ApiKeyAuth": [] }],
  "paths": {
    "/api/send-message": {
      "post": {
        "tags": ["Messaging"],
        "summary": "Send a text message",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["to", "message"],
                "properties": {
                  "to": { "type": "string", "description": "Recipient with country code, e.g. 923001234567", "example": "923001234567" },
                  "message": { "type": "string", "maxLength": 4096, "example": "Hello from API" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Sent or queued", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SendResult" } } } },
          "400": { "description": "Validation error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "404": { "description": "Recipient not on WhatsApp", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "429": { "description": "Rate limited" }
        }
      }
    },
    "/api/send-image": {
      "post": {
        "tags": ["Messaging"],
        "summary": "Send an image (URL or file upload)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["to"],
                "properties": {
                  "to": { "type": "string" },
                  "url": { "type": "string", "format": "uri" },
                  "caption": { "type": "string", "maxLength": 1024 },
                  "fileName": { "type": "string", "maxLength": 120 }
                }
              }
            },
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "to": { "type": "string" },
                  "file": { "type": "string", "format": "binary" },
                  "caption": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Sent or queued", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SendResult" } } } }
        }
      }
    },
    "/api/send-document": {
      "post": {
        "tags": ["Messaging"],
        "summary": "Send a document (PDF, Office, zip, etc.)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["to"],
                "properties": {
                  "to": { "type": "string" },
                  "url": { "type": "string", "format": "uri" },
                  "caption": { "type": "string", "maxLength": 1024 },
                  "fileName": { "type": "string", "maxLength": 120 }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Sent or queued", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SendResult" } } } }
        }
      }
    },
    "/api/send-audio": {
      "post": {
        "tags": ["Messaging"],
        "summary": "Send audio or voice note",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["to"],
                "properties": {
                  "to": { "type": "string" },
                  "url": { "type": "string", "format": "uri" },
                  "ptt": { "type": "boolean", "description": "true = send as voice note" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Sent or queued", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SendResult" } } } }
        }
      }
    },
    "/api/send-location": {
      "post": {
        "tags": ["Messaging"],
        "summary": "Send a location pin",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["to", "latitude", "longitude"],
                "properties": {
                  "to": { "type": "string" },
                  "latitude": { "type": "number", "minimum": -90, "maximum": 90 },
                  "longitude": { "type": "number", "minimum": -180, "maximum": 180 },
                  "name": { "type": "string", "maxLength": 200 },
                  "address": { "type": "string", "maxLength": 500 }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Sent or queued", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SendResult" } } } }
        }
      }
    },
    "/api/status": {
      "get": {
        "tags": ["Status"],
        "summary": "Connection and queue status",
        "responses": {
          "200": { "description": "Status", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Status" } } } }
        }
      }
    },
    "/api/messages": {
      "get": {
        "tags": ["Messages"],
        "summary": "Message queue and history",
        "parameters": [
          { "name": "status", "in": "query", "schema": { "type": "string", "enum": ["queued", "sent", "failed"] } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "minimum": 1, "maximum": 200, "default": 50 } }
        ],
        "responses": {
          "200": {
            "description": "Messages list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "counts": { "type": "object" },
                    "messages": { "type": "array", "items": { "$ref": "#/components/schemas/Message" } }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/me": {
      "get": {
        "tags": ["Auth"],
        "summary": "Info about your API key",
        "responses": {
          "200": { "description": "Key info" }
        }
      }
    },
    "/api/qr": {
      "get": {
        "tags": ["WhatsApp"],
        "summary": "Get QR code for linking",
        "parameters": [
          { "name": "format", "in": "query", "schema": { "type": "string", "enum": ["dataurl", "png"] } }
        ],
        "responses": {
          "200": { "description": "QR code data" },
          "409": { "description": "Already connected" }
        }
      }
    },
    "/api/logout": {
      "post": {
        "tags": ["WhatsApp"],
        "summary": "Unlink WhatsApp session (admin only)",
        "responses": {
          "200": { "description": "Logged out" },
          "403": { "description": "Admin required" }
        }
      }
    },
    "/api/admin/generate-key": {
      "post": {
        "tags": ["Admin"],
        "summary": "Generate a new API key",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": { "type": "string", "minLength": 2, "maxLength": 100 },
                  "role": { "type": "string", "enum": ["api", "admin"], "default": "api" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Key created" },
          "403": { "description": "Admin required" }
        }
      }
    },
    "/api/admin/revoke-key": {
      "post": {
        "tags": ["Admin"],
        "summary": "Revoke an API key",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["id"],
                "properties": {
                  "id": { "type": "string", "description": "Key prefix, e.g. wapi_xxxxxxxx" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Key revoked" },
          "403": { "description": "Admin required" }
        }
      }
    },
    "/api/admin/list-keys": {
      "get": {
        "tags": ["Admin"],
        "summary": "List all API keys",
        "responses": {
          "200": { "description": "Keys list" },
          "403": { "description": "Admin required" }
        }
      }
    },
    "/healthz": {
      "get": {
        "tags": ["System"],
        "summary": "Health check",
        "security": [],
        "responses": {
          "200": { "description": "Healthy" }
        }
      }
    }
  },
  "tags": [
    { "name": "Messaging", "description": "Send WhatsApp messages" },
    { "name": "Status", "description": "Connection and queue status" },
    { "name": "Messages", "description": "Message history" },
    { "name": "Auth", "description": "API key info" },
    { "name": "WhatsApp", "description": "Session management" },
    { "name": "Admin", "description": "Key management (admin only)" },
    { "name": "System", "description": "Health checks" }
  ]
}
